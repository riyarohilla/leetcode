You are given an n x n binary matrix grid. You are allowed to change at most one 0 to be 1.

Return the size of the largest island in grid after applying this operation.

An island is a 4-directionally connected group of 1s.

 

Example 1:

Input: grid = [[1,0],[0,1]]
Output: 3
Explanation: Change one 0 to 1 and connect two 1s, then we get an island with area = 3.
Example 2:

Input: grid = [[1,1],[1,0]]
Output: 4
Explanation: Change the 0 to 1 and make the island bigger, only one island with area = 4.
Example 3:

Input: grid = [[1,1],[1,1]]
Output: 4
Explanation: Can't change any 0 to 1, only one island with area = 4.
 

Constraints:

n == grid.length
n == grid[i].length
1 <= n <= 500
grid[i][j] is either 0 or 1.


-------------------------

T.C - O(n*n)


class Solution {
    public int largestIsland(int[][] grid) {
        int n = grid.length;
        Map<Integer, Integer> map = new HashMap<>();
        map.put(0, 0);
        int islandId = 2; // as 0, 1 is already there in grid
        
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < n; j++) {
                if(grid[i][j] == 1) {
                    int size = getIslandAndArea(grid, i, j, islandId);
                    map.put(islandId, size);
                    islandId++;
                }
            }
        }
        int ans = map.getOrDefault(2, 0);
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < n; j++) {
                if(grid[i][j] == 0) {
                    Set<Integer> set = new HashSet<>();
                    set.add(i > 0 ? grid[i-1][j] : 0);
                    set.add(j > 0 ? grid[i][j-1] : 0);
                    set.add(i < n-1 ? grid[i+1][j] : 0);
                    set.add(j < n-1 ? grid[i][j+1] : 0);
                    int totalArea = 1;
                    for(int id: set) {
                        totalArea += map.get(id);
                        ans = Math.max(ans, totalArea);
                    }
                }
            }
        }
        return ans;

    }

    int getIslandAndArea(int[][] grid, int i, int j, int islandId) {
        if(i < 0 || i >= grid.length || j < 0 || j >= grid.length || grid[i][j] != 1) {
            return 0;
        }
        grid[i][j] = islandId;
        return 1 + getIslandAndArea(grid, i + 1, j, islandId) + getIslandAndArea(grid, i - 1, j, islandId)
        + getIslandAndArea(grid, i, j + 1, islandId) + getIslandAndArea(grid, i, j - 1, islandId);
    }
}
