class Logger {

    Queue<Pair<String,Integer>> queue;
    Map<String,Integer> map;

    public Logger(){

        queue = new LinkedList<>();
        map = new HashMap<>();
    }

    public boolean shouldPrintMessage(int timestamp, String message){

        while(!queue.isEmpty() &&
              timestamp - queue.peek().getValue() >=10){

            Pair<String,Integer> old = queue.poll();

            if(map.get(old.getKey())
               == old.getValue()){

                map.remove(old.getKey());
            }
        }

        if(!map.containsKey(message)){

            map.put(message,timestamp);

            queue.add(new Pair(message,timestamp));

            return true;
        }

        return false;
    }
}
